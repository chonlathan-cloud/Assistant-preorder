# --- GCP Project Settings ---
GCP_PROJECT_ID=project001-489710
GCP_REGION=asia-southeast1

# --- Firestore Settings ---
FIRESTORE_COLLECTION=missions # ชื่อ database id

# --- Cloud Tasks Settings ---
# ชื่อ Queue ที่คุณสร้างใน Console
QUEUE_NAME=bot-mission-queue
# URL ของ Worker (Cloud Run) - จะได้หลังจาก Deploy Prompt #3
WORKER_URL=https://worker-service-xxx-as.a.run.app

# --- Secret Manager Settings ---
# ชื่อ Secret ที่คุณใช้เก็บคุกกี้
SECRET_ID_ACC_1=LAZ_SESSION_1
SECRET_ID_ACC_2=LAZ_SESSION_2

# --- Bot Configuration ---
# ตั้งค่าความเร็ว (ms) เช่น รอหน้าเว็บโหลดกี่วินาที
PAGE_LOAD_TIMEOUT=30000
# จำนวนครั้งที่จะลองกดใหม่ถ้าพลาด
MAX_RETRY=3